# Archivo de ejemplo para variables de entorno
# Copiar a .env y configurar valores según el ambiente

# ====================
# CONFIGURACIÓN DE BASE DE DATOS
# ====================
DATABASE_URL=mssql+pyodbc://sa:YourStrongPassword123@localhost/GestionTransporte?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
DB_SERVER=localhost
DB_NAME=GestionTransporte
DB_USER=sa
DB_PASSWORD=YourStrongPassword123

# ====================
# CONFIGURACIÓN JWT
# ====================
SECRET_KEY=tu_clave_secreta_super_segura_aqui_cambiala_en_produccion_debe_ser_larga_y_compleja
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====================
# CONFIGURACIÓN DE LA APLICACIÓN
# ====================
APP_NAME=Sistema de Gestión de Autotransporte
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ====================
# CORS (Orígenes permitidos)
# ====================
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost

# ====================
# CONFIGURACIÓN REGIONAL
# ====================
TIMEZONE=America/La_Paz
LOCALE=es_BO
CURRENCY=BOB

# ====================
# LOGS
# ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ====================
# ARCHIVOS
# ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ====================
# CONFIGURACIÓN DOCKER (Opcional)
# ====================
COMPOSE_PROJECT_NAME=gestion-transporte
DOCKER_REGISTRY=localhost:5000

# ====================
# CONFIGURACIÓN DE PRODUCCIÓN
# ====================
# Descomentar para producción
# DEBUG=False
# ENVIRONMENT=production
# SECRET_KEY=clave_produccion_super_segura_diferente_a_desarrollo
# DATABASE_URL=mssql+pyodbc://usuario:password@servidor_produccion/GestionTransporte?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=no
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com