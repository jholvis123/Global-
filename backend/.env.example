# Configuración de Base de Datos
DATABASE_URL=mssql+pyodbc://usuario:password@servidor/GestionTransporte?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes
DB_SERVER=localhost
DB_NAME=GestionTransporte
DB_USER=sa
DB_PASSWORD=YourStrongPassword123

# JWT Configuration
SECRET_KEY=tu_clave_secreta_super_segura_aqui_cambiala_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Configuración de la aplicación
APP_NAME=Sistema de Gestión de Autotransporte
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Configuración regional
TIMEZONE=America/La_Paz
LOCALE=es_BO
CURRENCY=BOB

# Logs
LOG_LEVEL=INFO
LOG_FORMAT=json

# Archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760